# Solana Vibestation gRPC Configuration
# Required: Your gRPC access token from Solana Vibestation
SVS_GRPC_TOKEN=your_grpc_token_here

# Optional: gRPC endpoint (defaults to basic tier if not specified)
SVS_GRPC_HTTP=https://basic.grpc.solanavibestation.com

# Solana RPC Configuration
# Optional: Solana RPC endpoint for token name resolution
# Defaults to public endpoint if not specified
HTTPS_ENDPOINT=https://api.mainnet-beta.solana.com

# Discord Integration
# Optional: Discord webhook URL for sending alerts
# Leave empty if you don't want Discord notifications
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Notes:
# - SVS_GRPC_TOKEN is required for the application to function
# - Get your gRPC token from: https://grpc.solanavibestation.com/
# - For Discord webhook, create a webhook in your Discord server settings
# - The application will work without HTTPS_ENDPOINT and DISCORD_WEBHOOK_URL
